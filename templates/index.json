      "type": "rich-text",
      "blocks": {
        "heading_DTwN3i": {
          "type": "heading",
          "settings": {
            "heading": "A different starting point",
            "heading_size": "h1"
          }
        },
        "text_hW8aMr": {
          "type": "text",
          "settings": {
