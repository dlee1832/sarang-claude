{{ 'chalttok-sarang.css' | asset_url | stylesheet_tag }}
{% render 'chalttok-fonts' %}

<style>
  /* Reset browser/theme blockquote defaults */
  #ct-manifesto-{{ section.id }} blockquote {
    margin: 0;
    padding: 0;
    border: none;
    border-left: none;
    quotes: none;
  }
  #ct-manifesto-{{ section.id }} blockquote::before,
  #ct-manifesto-{{ section.id }} blockquote::after {
    content: none;
  }

  /* Section padding */
  #ct-manifesto-{{ section.id }}.ct-manifesto {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  /* Gap: quote → rule */
  #ct-manifesto-{{ section.id }} .ct-manifesto__quote {
    margin-bottom: {{ section.settings.gap_quote_rule }}px;
  }

  /* Rule — fully explicit so base-CSS shorthand can't override */
  #ct-manifesto-{{ section.id }} .ct-manifesto__rule {
    display: block;
    width: {{ section.settings.rule_width }}px;
    height: {{ section.settings.rule_height }}px;
    background-color: {{ section.settings.rule_color | default: '#D9A99A' }};
    border-radius: {{ section.settings.rule_height | divided_by: 2 }}px;
    opacity: 1;
    margin-top: 0;
    margin-bottom: {{ section.settings.gap_rule_tag }}px;
    margin-left: 0;
    margin-right: 0;
    border: none;
  }

  #ct-manifesto-{{ section.id }} .ct-manifesto__sub {
    margin-top: 0;
  }
</style>

<section class="ct-manifesto" id="ct-manifesto-{{ section.id }}">
  <div class="ct-manifesto__inner ct-reveal">

    <blockquote class="ct-manifesto__quote">
      {{- section.settings.quote | newline_to_br -}}
    </blockquote>

    <div class="ct-manifesto__rule" role="separator"></div>

    {% if section.settings.brand_tag != blank %}
      <p class="ct-manifesto__sub">{{ section.settings.brand_tag }}</p>
    {% endif %}

  </div>
</section>

<script src="{{ 'chalttok-sarang.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CT · Manifesto",
  "tag": "div",
  "class": "chalttok-section",
  "settings": [
    {
      "type": "header",
      "content": "텍스트"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "인용문",
      "default": "\"Skin does not need more.\nIt needs balance.\""
    },
    {
      "type": "text",
      "id": "brand_tag",
      "label": "브랜드 태그",
      "default": "찰떡 · CHALTTOK"
    },
    {
      "type": "header",
      "content": "구분선"
    },
    {
      "type": "range",
      "id": "rule_width",
      "label": "구분선 길이",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "rule_height",
      "label": "구분선 두께",
      "min": 1,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "rule_color",
      "label": "구분선 색상",
      "default": "#D9A99A"
    },
    {
      "type": "header",
      "content": "간격"
    },
    {
      "type": "range",
      "id": "gap_quote_rule",
      "label": "인용구 → 구분선",
      "min": 12,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_rule_tag",
      "label": "구분선 → 브랜드 태그",
      "min": 12,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "header",
      "content": "섹션 여백"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "상단 여백",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 140
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "하단 여백",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 140
    }
  ],
  "presets": [
    {
      "name": "CT · Manifesto"
    }
  ]
}
{% endschema %}
