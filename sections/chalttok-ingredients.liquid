{{ 'chalttok-sarang.css' | asset_url | stylesheet_tag }}

<section class="ct-ingredients">

  <div class="ct-ingredients__img-wrap ct-reveal">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          class: 'ct-ingredients__img',
          loading: 'lazy',
          alt: section.settings.image.alt
      }}
    {% else %}
      {{ 'product-3' | placeholder_svg_tag: 'ct-ingredients__img placeholder-svg' }}
    {% endif %}
  </div>

  <div class="ct-ingredients__text ct-reveal ct-reveal--d1">
    <p class="ct-ingredients__section-label">{{ section.settings.section_label }}</p>
    <div class="ct-ing-row">
      {% for block in section.blocks %}
        <div class="ct-ing-item" {{ block.shopify_attributes }}>
          <div class="ct-ing-name">{{ block.settings.name }}</div>
          <div class="ct-ing-desc">{{ block.settings.description }}</div>
        </div>
      {% endfor %}
    </div>
  </div>

</section>

<script src="{{ 'chalttok-sarang.js' | asset_url }}" defer></script>



<style>
  #shopify-section-{{ section.id }} .ct-ing-name { font-weight: {{ section.settings.font_weight_heading }}; }
  #shopify-section-{{ section.id }} .ct-ing-desc,
  #shopify-section-{{ section.id }} .ct-ingredients__section-label { font-weight: {{ section.settings.font_weight_body }}; }

  {%- if section.settings.heading_font == 'cormorant' -%}
  #shopify-section-{{ section.id }} .ct-ing-name { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; }
  {%- elsif section.settings.heading_font == 'dm-sans' -%}
  #shopify-section-{{ section.id }} .ct-ing-name { font-family: 'DM Sans', 'Helvetica Neue', sans-serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'noto-kr' -%}
  #shopify-section-{{ section.id }} .ct-ing-name { font-family: 'Noto Serif KR', 'Nanum Myeongjo', serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'ny' -%}
  #shopify-section-{{ section.id }} .ct-ing-name { font-family: 'New York', ui-serif, Georgia, serif; font-style: normal; }
  {%- endif -%}
</style>
{% schema %}
{
  "name": "CT · Ingredients",
  "tag": "div",
  "class": "chalttok-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Close-up of ingredients or annotated drop shot"
    },
    {
      "type": "text",
      "id": "section_label",
      "label": "Section label",
      "default": "What's inside"
    }
,
    {
      "type": "header",
      "content": "폰트"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "헤딩 폰트",
      "options": [
        { "value": "default",   "label": "기본 (현재 폰트 유지)" },
        { "value": "cormorant", "label": "Cormorant (이탤릭 세리프)" },
        { "value": "dm-sans",   "label": "DM Sans (모던 산세리프)" },
        { "value": "noto-kr",   "label": "Noto Serif KR (한글 세리프)" },
        { "value": "ny",        "label": "New York (애플 세리프)" }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient name",
          "default": "Niacinamide"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Benefit",
          "default": "Calms, evens tone, restores barrier"
        }
      ]
    },
    {
      "type": "header",
      "content": "폰트 두께"
    },
    {
      "type": "select",
      "id": "font_weight_heading",
      "label": "헤딩 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" },
        { "value": "700", "label": "700 — Bold" }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "font_weight_body",
      "label": "본문 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" }
      ],
      "default": "300"
    }
  ],
  "presets": [
    {
      "name": "CT · Ingredients",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "name": "Niacinamide",
            "description": "Calms, evens tone, restores barrier"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Hyaluronic Acid",
            "description": "Deep, lasting hydration without weight"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Panthenol",
            "description": "Soothes skin, seals in moisture"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Pomegranate Extract",
            "description": "Antioxidant care, naturally derived"
          }
        }
      ]
    }
  ]
}
{% endschema %}
