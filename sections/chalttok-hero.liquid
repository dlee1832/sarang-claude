{{ 'chalttok-sarang.css' | asset_url | stylesheet_tag }}
{{ 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300&family=DM+Sans:wght@300&family=Noto+Serif+KR:wght@200&display=swap' | stylesheet_tag }}

<div class="ct-hero" id="ct-hero-{{ section.id }}">

  {% if section.settings.image != blank %}
    {{
      section.settings.image
      | image_url: width: 2000
      | image_tag:
        class: 'ct-hero__bg',
        loading: 'eager',
        fetchpriority: 'high',
        alt: section.settings.image.alt
    }}
  {% else %}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'ct-hero__bg placeholder-svg' }}
  {% endif %}

  <div class="ct-hero__overlay"></div>
  <div class="ct-hero__vignette"></div>

  {% if section.settings.show_illustration %}
  <svg class="ct-hero__svg" viewBox="0 0 1400 900" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <radialGradient id="ct-skinG-{{ section.id }}" cx="45%" cy="38%" r="62%">
        <stop offset="0%"   stop-color="#F5D8CE" stop-opacity="0.97"/>
        <stop offset="45%"  stop-color="#ECC8BC" stop-opacity="0.94"/>
        <stop offset="80%"  stop-color="#D9AFA3" stop-opacity="0.9"/>
        <stop offset="100%" stop-color="#C89A8E" stop-opacity="0.85"/>
      </radialGradient>
      <radialGradient id="ct-cheekR-{{ section.id }}" cx="50%" cy="50%" r="50%">
        <stop offset="0%"   stop-color="#E8B0A4" stop-opacity="0.3"/>
        <stop offset="100%" stop-color="#E8B0A4" stop-opacity="0"/>
      </radialGradient>
      <linearGradient id="ct-hairG-{{ section.id }}" x1="0%" y1="0%" x2="60%" y2="100%">
        <stop offset="0%"   stop-color="#2A1E1A"/>
        <stop offset="100%" stop-color="#1A100C"/>
      </linearGradient>
      <linearGradient id="ct-waterG-{{ section.id }}" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%"   stop-color="#C0A8A0" stop-opacity="0"/>
        <stop offset="35%"  stop-color="#C8B0A8" stop-opacity="0.35"/>
        <stop offset="100%" stop-color="#C4ACA4" stop-opacity="0.72"/>
      </linearGradient>
      <filter id="ct-soft-{{ section.id }}"><feGaussianBlur stdDeviation="1.5"/></filter>
      <filter id="ct-softer-{{ section.id }}"><feGaussianBlur stdDeviation="3"/></filter>
    </defs>

    <rect width="1400" height="900" fill="rgba(180,148,140,0.12)"/>
    <rect x="650" y="685" width="100" height="215" rx="18" fill="url(#ct-skinG-{{ section.id }})"/>
    <ellipse cx="700" cy="870" rx="220" ry="55" fill="url(#ct-skinG-{{ section.id }})" opacity="0.6"/>
    <ellipse cx="700" cy="530" rx="148" ry="178" fill="url(#ct-skinG-{{ section.id }})"/>
    <ellipse cx="700" cy="530" rx="148" ry="178" fill="rgba(255,248,244,0.06)" filter="url(#ct-soft-{{ section.id }})"/>
    <ellipse cx="590" cy="570" rx="55" ry="32" fill="url(#ct-cheekR-{{ section.id }})" opacity="0.75"/>
    <ellipse cx="810" cy="570" rx="55" ry="32" fill="url(#ct-cheekR-{{ section.id }})" opacity="0.75"/>
    <ellipse cx="700" cy="400" rx="160" ry="148" fill="url(#ct-hairG-{{ section.id }})"/>
    <path d="M560,410 Q540,340 570,290 Q600,240 650,218 Q700,205 750,218 Q800,240 830,290 Q860,340 840,410" fill="url(#ct-hairG-{{ section.id }})"/>
    <path d="M556,440 Q530,470 540,530 Q545,575 555,610" stroke="#1A100C" stroke-width="32" fill="none" stroke-linecap="round" opacity="0.9"/>
    <path d="M844,440 Q870,470 860,530 Q855,575 845,610" stroke="#1A100C" stroke-width="32" fill="none" stroke-linecap="round" opacity="0.9"/>
    <path d="M615,462 Q638,452 662,456" stroke="#5A3C34" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.85"/>
    <path d="M738,456 Q762,452 785,462" stroke="#5A3C34" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.85"/>
    <path d="M615,490 Q638,481 662,490" stroke="#2C1E1A" stroke-width="2.2" fill="none" stroke-linecap="round"/>
    <path d="M615,490 Q638,499 662,490" fill="#2C1E1A" opacity="0.1"/>
    <path d="M738,490 Q762,481 785,490" stroke="#2C1E1A" stroke-width="2.2" fill="none" stroke-linecap="round"/>
    <path d="M738,490 Q762,499 785,490" fill="#2C1E1A" opacity="0.1"/>
    <path d="M618,494 Q638,498 660,494" stroke="#5A3C34" stroke-width="0.9" fill="none" opacity="0.3"/>
    <path d="M740,494 Q762,498 782,494" stroke="#5A3C34" stroke-width="0.9" fill="none" opacity="0.3"/>
    <path d="M692,545 Q680,568 664,578 Q680,584 700,582 Q720,584 736,578 Q720,568 708,545" stroke="#C8908A" stroke-width="1.4" fill="none" opacity="0.4" stroke-linecap="round"/>
    <path d="M651,640 Q676,633 700,634 Q724,633 749,640 Q738,652 700,655 Q662,652 651,640Z" fill="#C0908A" opacity="0.5"/>
    <path d="M651,640 Q676,636 700,637 Q724,636 749,640" stroke="#B88480" stroke-width="0.9" fill="none" opacity="0.55"/>
    <path d="M668,635 Q683,629 700,635 Q717,629 732,635" stroke="#B88480" stroke-width="0.8" fill="none" opacity="0.35"/>
    <ellipse cx="700" cy="415" rx="60" ry="22" fill="rgba(255,248,244,0.1)" filter="url(#ct-soft-{{ section.id }})"/>
    <ellipse cx="700" cy="475" rx="7"  ry="22" fill="rgba(255,248,244,0.12)" filter="url(#ct-soft-{{ section.id }})"/>
    <rect x="0" y="678" width="1400" height="2.5" fill="rgba(196,172,165,0.55)"/>
    <rect x="0" y="672" width="1400" height="16"  fill="rgba(210,188,182,0.12)" filter="url(#ct-softer-{{ section.id }})"/>
    <rect x="0" y="680" width="1400" height="220" fill="url(#ct-waterG-{{ section.id }})"/>
    <ellipse cx="700" cy="680" rx="80" ry="12" fill="url(#ct-skinG-{{ section.id }})" opacity="0.55"/>
    <ellipse cx="700" cy="360" rx="200" ry="120" fill="rgba(255,248,244,0.06)" filter="url(#ct-softer-{{ section.id }})"/>
    <ellipse cx="600" cy="560" rx="80"  ry="50"  fill="rgba(255,248,244,0.05)" filter="url(#ct-softer-{{ section.id }})"/>
    <ellipse cx="800" cy="560" rx="80"  ry="50"  fill="rgba(255,248,244,0.05)" filter="url(#ct-softer-{{ section.id }})"/>
  </svg>
  {% endif %}

  <div class="ct-hero__words">
    <div class="ct-hero__name">{{ section.settings.heading }}</div>
    {% if section.settings.kr_text != blank %}
      <div class="ct-hero__kr">{{ section.settings.kr_text }}</div>
    {% endif %}
    {% if section.settings.subtext != blank %}
      <div class="ct-hero__sub">{{ section.settings.subtext }}</div>
    {% endif %}
  </div>

  <div class="ct-scroll-cue" aria-hidden="true">
    <div class="ct-scroll-line"></div>
    <span>scroll</span>
  </div>

</div>

<script src="{{ 'chalttok-sarang.js' | asset_url }}" defer></script>



<style>
  #shopify-section-{{ section.id }} .ct-hero__name { font-weight: {{ section.settings.font_weight_heading }}; }
  #shopify-section-{{ section.id }} .ct-hero__kr,
  #shopify-section-{{ section.id }} .ct-hero__sub { font-weight: {{ section.settings.font_weight_body }}; }

  {%- if section.settings.heading_font == 'cormorant' -%}
  #shopify-section-{{ section.id }} .ct-hero__name { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; }
  {%- elsif section.settings.heading_font == 'dm-sans' -%}
  #shopify-section-{{ section.id }} .ct-hero__name { font-family: 'DM Sans', 'Helvetica Neue', sans-serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'noto-kr' -%}
  #shopify-section-{{ section.id }} .ct-hero__name { font-family: 'Noto Serif KR', 'Nanum Myeongjo', serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'ny' -%}
  #shopify-section-{{ section.id }} .ct-hero__name { font-family: 'New York', ui-serif, Georgia, serif; font-style: normal; }
  {%- endif -%}
</style>
{% schema %}
{
  "name": "CT · Hero",
  "tag": "div",
  "class": "chalttok-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Brand name",
      "default": "Sarang"
    },
    {
      "type": "text",
      "id": "kr_text",
      "label": "Korean subtitle",
      "default": "사랑 · 귀하신 이름"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "English subtitle",
      "default": "CHALTTOK · First Product"
    },
    {
      "type": "checkbox",
      "id": "show_illustration",
      "label": "Show SVG illustration",
      "default": true,
      "info": "Illustrated woman in water over the hero image"
    },
    {
      "type": "header",
      "content": "폰트"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "헤딩 폰트",
      "options": [
        { "value": "default",   "label": "기본 (현재 폰트 유지)" },
        { "value": "cormorant", "label": "Cormorant (이탤릭 세리프)" },
        { "value": "dm-sans",   "label": "DM Sans (모던 산세리프)" },
        { "value": "noto-kr",   "label": "Noto Serif KR (한글 세리프)" },
        { "value": "ny",        "label": "New York (애플 세리프)" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "폰트 두께"
    },
    {
      "type": "select",
      "id": "font_weight_heading",
      "label": "헤딩 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" },
        { "value": "700", "label": "700 — Bold" }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "font_weight_body",
      "label": "본문 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" }
      ],
      "default": "300"
    }
  ],
  "presets": [
    {
      "name": "CT · Hero"
    }
  ]
}
{% endschema %}
