{{ 'chalttok-sarang.css' | asset_url | stylesheet_tag }}

<section class="ct-panels">
  {% for block in section.blocks %}
    <div class="ct-panel ct-reveal{% if forloop.index > 1 %} ct-reveal--d{{ forloop.index | minus: 1 }}{% endif %}"
         {{ block.shopify_attributes }}>
      {% if block.settings.image != blank %}
        {{
          block.settings.image
          | image_url: width: 900
          | image_tag:
            class: 'ct-panel__img',
            loading: 'lazy',
            alt: block.settings.image.alt
        }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'ct-panel__img placeholder-svg' }}
      {% endif %}
      <div class="ct-panel__overlay"></div>
      {% if block.settings.label != blank %}
        <span class="ct-panel__label">{{ block.settings.label }}</span>
      {% endif %}
    </div>
  {% endfor %}
</section>

<script src="{{ 'chalttok-sarang.js' | asset_url }}" defer></script>



<style>
  #shopify-section-{{ section.id }} .ct-panel__label { font-weight: {{ section.settings.font_weight_heading }}; }

  {%- if section.settings.heading_font == 'cormorant' -%}
  #shopify-section-{{ section.id }} .ct-panel__label { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; }
  {%- elsif section.settings.heading_font == 'dm-sans' -%}
  #shopify-section-{{ section.id }} .ct-panel__label { font-family: 'DM Sans', 'Helvetica Neue', sans-serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'noto-kr' -%}
  #shopify-section-{{ section.id }} .ct-panel__label { font-family: 'Noto Serif KR', 'Nanum Myeongjo', serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'ny' -%}
  #shopify-section-{{ section.id }} .ct-panel__label { font-family: 'New York', ui-serif, Georgia, serif; font-style: normal; }
  {%- endif -%}
</style>
{% schema %}
{
  "name": "CT · Three Panels",
  "tag": "div",
  "class": "chalttok-section",
  "max_blocks": 3,
  "settings": [,
    {
      "type": "header",
      "content": "폰트"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "헤딩 폰트",
      "options": [
        { "value": "default",   "label": "기본 (현재 폰트 유지)" },
        { "value": "cormorant", "label": "Cormorant (이탤릭 세리프)" },
        { "value": "dm-sans",   "label": "DM Sans (모던 산세리프)" },
        { "value": "noto-kr",   "label": "Noto Serif KR (한글 세리프)" },
        { "value": "ny",        "label": "New York (애플 세리프)" }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Hover label"
        }
      ]
    },
    {
      "type": "header",
      "content": "폰트 두께"
    },
    {
      "type": "select",
      "id": "font_weight_heading",
      "label": "헤딩 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" },
        { "value": "700", "label": "700 — Bold" }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "font_weight_body",
      "label": "본문 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" }
      ],
      "default": "300"
    }
  ],
  "presets": [
    {
      "name": "CT · Three Panels",
      "blocks": [
        {
          "type": "panel",
          "settings": { "label": "skin meets serum" }
        },
        {
          "type": "panel",
          "settings": { "label": "pomegranate extract" }
        },
        {
          "type": "panel",
          "settings": { "label": "crafted with clarity" }
        }
      ]
    }
  ]
}
{% endschema %}
