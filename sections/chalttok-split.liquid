{{ 'chalttok-sarang.css' | asset_url | stylesheet_tag }}

<section class="ct-split{% if section.settings.image_position == 'right' %} ct-split--reversed{% endif %}">

  <div class="ct-split__img-wrap ct-reveal">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          class: 'ct-split__img',
          loading: 'lazy',
          alt: section.settings.image.alt
      }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'ct-split__img placeholder-svg' }}
    {% endif %}
  </div>

  <div class="ct-split__text ct-reveal ct-reveal--d1">
    {% if section.settings.label != blank %}
      <p class="ct-split__label">{{ section.settings.label }}</p>
    {% endif %}
    <h2 class="ct-split__heading">{{ section.settings.heading | newline_to_br }}</h2>
    {% if section.settings.body_text != blank %}
      <p class="ct-split__body">{{ section.settings.body_text }}</p>
    {% endif %}
  </div>

</section>

<script src="{{ 'chalttok-sarang.js' | asset_url }}" defer></script>



<style>
  #shopify-section-{{ section.id }} .ct-split__heading { font-weight: {{ section.settings.font_weight_heading }}; }
  #shopify-section-{{ section.id }} .ct-split__label,
  #shopify-section-{{ section.id }} .ct-split__body { font-weight: {{ section.settings.font_weight_body }}; }

  {%- if section.settings.heading_font == 'cormorant' -%}
  #shopify-section-{{ section.id }} .ct-split__heading { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; }
  {%- elsif section.settings.heading_font == 'dm-sans' -%}
  #shopify-section-{{ section.id }} .ct-split__heading { font-family: 'DM Sans', 'Helvetica Neue', sans-serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'noto-kr' -%}
  #shopify-section-{{ section.id }} .ct-split__heading { font-family: 'Noto Serif KR', 'Nanum Myeongjo', serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'ny' -%}
  #shopify-section-{{ section.id }} .ct-split__heading { font-family: 'New York', ui-serif, Georgia, serif; font-style: normal; }
  {%- endif -%}
</style>
{% schema %}
{
  "name": "CT · Philosophy Split",
  "tag": "div",
  "class": "chalttok-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Micro label",
      "default": "A Different Beginning"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "One step.\nDone with care."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "We asked what skin truly needs — not what the industry decided. The answer was simple: moisture, rest, and a gentle beginning every day."
    },
    {
      "type": "header",
      "content": "폰트"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "헤딩 폰트",
      "options": [
        { "value": "default",   "label": "기본 (현재 폰트 유지)" },
        { "value": "cormorant", "label": "Cormorant (이탤릭 세리프)" },
        { "value": "dm-sans",   "label": "DM Sans (모던 산세리프)" },
        { "value": "noto-kr",   "label": "Noto Serif KR (한글 세리프)" },
        { "value": "ny",        "label": "New York (애플 세리프)" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "폰트 두께"
    },
    {
      "type": "select",
      "id": "font_weight_heading",
      "label": "헤딩 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" },
        { "value": "700", "label": "700 — Bold" }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "font_weight_body",
      "label": "본문 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" }
      ],
      "default": "300"
    }
  ],
  "presets": [
    {
      "name": "CT · Philosophy Split"
    }
  ]
}
{% endschema %}
