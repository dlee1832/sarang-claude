{{ 'chalttok-sarang.css' | asset_url | stylesheet_tag }}

{%- liquid
  comment
    Overlay opacity: convert 0-90 integer → 0.00-0.90 float for rgba()
  endcomment
  assign _overlay_alpha = section.settings.overlay_opacity | times: 1.0 | divided_by: 100 | round: 2

  comment
    Text background color + opacity
  endcomment
  if section.settings.text_bg_enabled
    assign _text_bg_alpha = section.settings.text_bg_opacity | times: 1.0 | divided_by: 100 | round: 2
    if section.settings.text_bg_style == 'frosted'
      assign _bg_r = 255
      assign _bg_g = 250
      assign _bg_b = 247
      assign _bg_extra = 'backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);'
    elsif section.settings.text_bg_style == 'warm'
      assign _bg_r = 72
      assign _bg_g = 52
      assign _bg_b = 44
      assign _bg_extra = ''
    else
      assign _bg_r = 26
      assign _bg_g = 20
      assign _bg_b = 18
      assign _bg_extra = ''
    endif
  endif

  comment
    Text color: explicit setting > frosted-auto-dark > default ivory
  endcomment
  if section.settings.text_color == 'black'
    assign _label_color   = 'rgba(0,0,0,0.55)'
    assign _heading_color = '#000000'
    assign _caption_color = 'rgba(0,0,0,0.7)'
    assign _accent_color  = 'rgba(0,0,0,0.2)'
  elsif section.settings.text_color == 'ink'
    assign _label_color   = 'rgba(44,36,32,0.55)'
    assign _heading_color = '#2C2420'
    assign _caption_color = 'rgba(44,36,32,0.7)'
    assign _accent_color  = 'rgba(44,36,32,0.25)'
  elsif section.settings.text_bg_enabled and section.settings.text_bg_style == 'frosted'
    assign _label_color   = 'rgba(44,36,32,0.55)'
    assign _heading_color = '#2C2420'
    assign _caption_color = 'rgba(44,36,32,0.7)'
    assign _accent_color  = 'rgba(44,36,32,0.25)'
  else
    assign _label_color   = 'rgba(248,244,238,0.5)'
    assign _heading_color = '#F8F4EE'
    assign _caption_color = 'rgba(248,244,238,0.55)'
    assign _accent_color  = 'rgba(248,244,238,0.38)'
  endif
-%}

{%- style -%}
  /* ── Section height & image focus ── */
  #ct-overload-{{ section.id }} {
    height: calc(100vh + {{ section.settings.section_padding_bottom }}px);
  }
  #ct-overload-{{ section.id }} .ct-overload__img {
    object-position: center {{ section.settings.image_focus_y }}%;
  }

  /* ── Overlay gradient — rgba() for universal browser support ── */
  #ct-overload-{{ section.id }} .ct-overload__overlay {
    background: linear-gradient(
      to bottom,
      transparent 30%,
      rgba(44, 36, 32, {{ _overlay_alpha }}) 100%
    );
  }

  /* ── Text colors ── */
  #ct-overload-{{ section.id }} .ct-label-micro  { color: {{ _label_color }}; }
  #ct-overload-{{ section.id }} .ct-statement-lg { color: {{ _heading_color }}; }
  #ct-overload-{{ section.id }} .ct-caption-sm   { color: {{ _caption_color }}; }

  /* ── Accent line color ── */
  #ct-overload-{{ section.id }} .ct-overload__accent {
    background: {{ _accent_color }};
  }

  /* ── Text block position ── */
  #ct-overload-{{ section.id }} .ct-overload__text {
    bottom: {{ section.settings.text_bottom }}px;
  }

  /* ── Text background box (optional) ── */
  {%- if section.settings.text_bg_enabled -%}
  #ct-overload-{{ section.id }} .ct-overload__text {
    bottom: {{ section.settings.text_bottom }}px;
    background: rgba({{ _bg_r }}, {{ _bg_g }}, {{ _bg_b }}, {{ _text_bg_alpha }});
    padding: 32px 40px;
    border-radius: 2px;
    max-width: 520px;
    {{ _bg_extra }}
  }
  {%- endif -%}

  /* ── Heading font variants ── */
  #ct-overload-{{ section.id }} .ct-overload__heading--serif {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
  }
  #ct-overload-{{ section.id }} .ct-overload__heading--sans {
    font-family: 'DM Sans', 'Helvetica Neue', sans-serif;
    font-style: normal;
    font-weight: 200;
    letter-spacing: 0.02em;
  }
  #ct-overload-{{ section.id }} .ct-overload__heading--kr {
    font-family: 'Noto Serif KR', 'Nanum Myeongjo', serif;
    font-style: normal;
    font-weight: 200;
    letter-spacing: 0.05em;
  }
  #ct-overload-{{ section.id }} .ct-overload__heading--ny {
    font-family: 'New York', ui-serif, Georgia, serif;
    font-style: normal;
  }

  /* ── Font weights ── */
  #shopify-section-{{ section.id }} .ct-statement-lg { font-weight: {{ section.settings.font_weight_heading }}; }
  #shopify-section-{{ section.id }} .ct-label-micro,
  #shopify-section-{{ section.id }} .ct-caption-sm   { font-weight: {{ section.settings.font_weight_body }}; }

  /* ── Heading font (heading_font selector) ── */
  {%- if section.settings.heading_font == 'cormorant' -%}
  #shopify-section-{{ section.id }} .ct-statement-lg { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; }
  {%- elsif section.settings.heading_font == 'dm-sans' -%}
  #shopify-section-{{ section.id }} .ct-statement-lg { font-family: 'DM Sans', 'Helvetica Neue', sans-serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'noto-kr' -%}
  #shopify-section-{{ section.id }} .ct-statement-lg { font-family: 'Noto Serif KR', 'Nanum Myeongjo', serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'ny' -%}
  #shopify-section-{{ section.id }} .ct-statement-lg { font-family: 'New York', ui-serif, Georgia, serif; font-style: normal; }
  {%- endif -%}
{%- endstyle -%}

<section class="ct-overload" id="ct-overload-{{ section.id }}">

  {% if section.settings.image != blank %}
    {{
      section.settings.image
      | image_url: width: 2000
      | image_tag:
        class: 'ct-overload__img',
        loading: 'lazy',
        alt: section.settings.image.alt
    }}
  {% else %}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'ct-overload__img placeholder-svg' }}
  {% endif %}

  <div class="ct-overload__overlay"></div>

  <div class="ct-overload__text">
    <span class="ct-overload__accent ct-reveal" aria-hidden="true"></span>
    {% if section.settings.label != blank %}
      <p class="ct-label-micro ct-reveal ct-reveal--d1">{{ section.settings.label }}</p>
    {% endif %}
    <h2
      class="ct-statement-lg ct-reveal ct-reveal--d2 ct-overload__heading--{{ section.settings.heading_font }}"
      style="font-size: clamp({{ section.settings.heading_size_min }}px, 4vw, {{ section.settings.heading_size_max }}px);"
    >
      {{- section.settings.heading | newline_to_br -}}
    </h2>
    {% if section.settings.caption != blank %}
      <p class="ct-caption-sm ct-reveal ct-reveal--d3">{{ section.settings.caption }}</p>
    {% endif %}
  </div>

</section>

<script src="{{ 'chalttok-sarang.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CT · Overwhelm",
  "tag": "div",
  "class": "chalttok-section",
  "settings": [
    {
      "type": "header",
      "content": "이미지"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "배경 이미지",
      "info": "제품이 많이 담긴 사진을 권장합니다."
    },
    {
      "type": "header",
      "content": "오버레이 (이미지 위 어두운 그라데이션)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "오버레이 불투명도",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 55,
      "info": "높을수록 이미지 하단이 어두워져 텍스트 가독성이 올라갑니다."
    },
    {
      "type": "header",
      "content": "텍스트 배경 박스"
    },
    {
      "type": "checkbox",
      "id": "text_bg_enabled",
      "label": "텍스트 배경 박스 사용",
      "default": false,
      "info": "글자 뒤에 반투명 박스를 표시합니다. 오버레이 불투명도가 낮을 때 효과적입니다."
    },
    {
      "type": "select",
      "id": "text_bg_style",
      "label": "배경 박스 스타일",
      "options": [
        { "value": "dark",    "label": "딥 다크 (진한 검정)" },
        { "value": "warm",    "label": "웜 다크 (따뜻한 갈색)" },
        { "value": "frosted", "label": "프로스티드 (흰 유리효과)" }
      ],
      "default": "warm"
    },
    {
      "type": "range",
      "id": "text_bg_opacity",
      "label": "배경 박스 불투명도",
      "min": 10,
      "max": 85,
      "step": 5,
      "unit": "%",
      "default": 45,
      "info": "낮을수록 투명하게 이미지가 비쳐 보입니다."
    },
    {
      "type": "header",
      "content": "텍스트"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "글자 색상",
      "options": [
        { "value": "white", "label": "흰색 / 아이보리 (기본 — 어두운 배경용)" },
        { "value": "ink",   "label": "잉크 (따뜻한 검정 #2C2420)" },
        { "value": "black", "label": "순수 검정 (#000000)" }
      ],
      "default": "white",
      "info": "배경이 밝은 이미지이거나 프로스티드 박스 사용 시 '잉크' 또는 '순수 검정'을 선택하세요."
    },
    {
      "type": "text",
      "id": "label",
      "label": "상단 소제목",
      "default": "The Familiar Fatigue"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "헤딩",
      "default": "When did caring\nbecome so heavy?"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "헤딩 폰트",
      "options": [
        { "value": "serif",    "label": "Cormorant (이탤릭 세리프, 기본)" },
        { "value": "sans",     "label": "DM Sans (모던 산세리프)" },
        { "value": "kr",       "label": "Noto Serif KR (한글 세리프)" },
        { "value": "ny",       "label": "New York (애플 세리프)" }
      ],
      "default": "serif"
    },
    {
      "type": "range",
      "id": "heading_size_min",
      "label": "헤딩 최소 크기 (모바일)",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_max",
      "label": "헤딩 최대 크기 (데스크탑)",
      "min": 36,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 52
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "캡션",
      "default": "Twelve steps. Twenty products. Skin exhausted by the very things meant to help it."
    },
    {
      "type": "header",
      "content": "레이아웃"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "섹션 하단 여백 (이미지 확장)",
      "min": 0,
      "max": 240,
      "step": 20,
      "unit": "px",
      "default": 100,
      "info": "섹션을 아래로 늘려 이미지 하단에 더 많은 공간을 만들고, 글자를 아래쪽 여백으로 내립니다."
    },
    {
      "type": "range",
      "id": "text_bottom",
      "label": "텍스트 하단 위치",
      "min": 24,
      "max": 200,
      "step": 8,
      "unit": "px",
      "default": 80,
      "info": "텍스트 블록이 섹션 하단에서 얼마나 위에 위치할지 설정합니다."
    },
    {
      "type": "range",
      "id": "image_focus_y",
      "label": "이미지 세로 초점",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40,
      "info": "값이 작을수록 이미지 위쪽이 기준이 되어 하단에 여백이 생깁니다."
    },
    {
      "type": "header",
      "content": "폰트 두께"
    },
    {
      "type": "select",
      "id": "font_weight_heading",
      "label": "헤딩 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" },
        { "value": "700", "label": "700 — Bold" }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "font_weight_body",
      "label": "본문 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" }
      ],
      "default": "300"
    }
  ],
  "presets": [
    {
      "name": "CT · Overwhelm"
    }
  ]
}
{% endschema %}
