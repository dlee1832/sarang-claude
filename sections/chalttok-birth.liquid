{{ 'chalttok-sarang.css' | asset_url | stylesheet_tag }}

<section class="ct-birth">

  <div class="ct-birth__text ct-reveal">
    {% if section.settings.number != blank %}
      <div class="ct-birth__number" aria-hidden="true">{{ section.settings.number }}</div>
    {% endif %}
    <h2 class="ct-birth__heading">{{ section.settings.heading | newline_to_br }}</h2>
    {% if section.settings.body_text != blank %}
      <p class="ct-birth__body">{{ section.settings.body_text }}</p>
    {% endif %}
    {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
      <a href="{{ section.settings.cta_url }}" class="ct-birth__cta">
        {{ section.settings.cta_label }}
      </a>
    {% endif %}
  </div>

  <div class="ct-birth__img-wrap ct-reveal ct-reveal--d1">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          class: 'ct-birth__img',
          loading: 'lazy',
          alt: section.settings.image.alt
      }}
    {% else %}
      {{ 'product-2' | placeholder_svg_tag: 'ct-birth__img placeholder-svg' }}
    {% endif %}
  </div>

</section>

<script src="{{ 'chalttok-sarang.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CT · Product Reveal",
  "tag": "div",
  "class": "chalttok-section",
  "settings": [
    {
      "type": "text",
      "id": "number",
      "label": "Decorative number",
      "default": "01"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Product name / heading",
      "default": "Sarang\nFacial Serum"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Description",
      "default": "Named for love. Formulated with restraint. A blush-pink serum that absorbs in silence and asks for nothing more."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    }
  ],
  "presets": [
    {
      "name": "CT · Product Reveal"
    }
  ]
}
{% endschema %}
