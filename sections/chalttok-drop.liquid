{{ 'chalttok-sarang.css' | asset_url | stylesheet_tag }}

<section class="ct-drop">

  {% if section.settings.image != blank %}
    {{
      section.settings.image
      | image_url: width: 2000
      | image_tag:
        class: 'ct-drop__img',
        loading: 'lazy',
        alt: section.settings.image.alt
    }}
  {% else %}
    {{ 'product-1' | placeholder_svg_tag: 'ct-drop__img placeholder-svg' }}
  {% endif %}

  <div class="ct-drop__caption ct-reveal ct-reveal--d1">
    <div class="ct-drop__word">{{ section.settings.word | newline_to_br }}</div>
    {% if section.settings.sub_text != blank %}
      <div class="ct-drop__sub">{{ section.settings.sub_text }}</div>
    {% endif %}
  </div>

</section>

<script src="{{ 'chalttok-sarang.js' | asset_url }}" defer></script>



<style>
  #shopify-section-{{ section.id }} .ct-drop__word { font-weight: {{ section.settings.font_weight_heading }}; }
  #shopify-section-{{ section.id }} .ct-drop__sub { font-weight: {{ section.settings.font_weight_body }}; }
</style>
{% schema %}
{
  "name": "CT · Full Bleed Drop",
  "tag": "div",
  "class": "chalttok-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Full-bleed image",
      "info": "Close-up serum / product shot works best"
    },
    {
      "type": "textarea",
      "id": "word",
      "label": "Large overlay word",
      "default": "One\ndrop."
    },
    {
      "type": "text",
      "id": "sub_text",
      "label": "Sub-label below word",
      "default": "Blush pink · Bouncy · Weightless"
    },
    {
      "type": "header",
      "content": "폰트 두께"
    },
    {
      "type": "select",
      "id": "font_weight_heading",
      "label": "헤딩 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" },
        { "value": "700", "label": "700 — Bold" }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "font_weight_body",
      "label": "본문 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" }
      ],
      "default": "300"
    }
  ],
  "presets": [
    {
      "name": "CT · Full Bleed Drop"
    }
  ]
}
{% endschema %}
