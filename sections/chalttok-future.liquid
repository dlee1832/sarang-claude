{{ 'chalttok-sarang.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign _has_image = false
  if section.settings.image != blank
    assign _has_image = true
    assign _overlay_alpha = section.settings.overlay_opacity | times: 1.0 | divided_by: 100 | round: 2
  endif

  if section.settings.text_color == 'white'
    assign _heading_color = '#F8F4EE'
    assign _caption_color = 'rgba(248,244,238,0.65)'
    assign _line_color    = 'rgba(217,169,154,0.7)'
  elsif section.settings.text_color == 'black'
    assign _heading_color = '#000000'
    assign _caption_color = 'rgba(0,0,0,0.6)'
    assign _line_color    = 'rgba(0,0,0,0.25)'
  else
    assign _heading_color = ''
    assign _caption_color = ''
    assign _line_color    = ''
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .ct-future {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    justify-content: {{ section.settings.text_v_pos }};
  }

  {%- if _has_image -%}
  #shopify-section-{{ section.id }} .ct-future {
    position: relative;
    overflow: hidden;
    min-height: {{ section.settings.section_min_height }}px;
  }
  #shopify-section-{{ section.id }} .ct-future__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center {{ section.settings.image_focus_y }}%;
  }
  #shopify-section-{{ section.id }} .ct-future__overlay {
    position: absolute;
    inset: 0;
    background: rgba(44, 36, 32, {{ _overlay_alpha }});
  }
  #shopify-section-{{ section.id }} .ct-future__line,
  #shopify-section-{{ section.id }} .ct-future__heading,
  #shopify-section-{{ section.id }} .ct-future__caption {
    position: relative;
    z-index: 2;
  }
  {%- endif -%}

  {%- if _heading_color != '' -%}
  #shopify-section-{{ section.id }} .ct-future__heading { color: {{ _heading_color }}; }
  #shopify-section-{{ section.id }} .ct-future__caption { color: {{ _caption_color }}; }
  #shopify-section-{{ section.id }} .ct-future__line    { background: linear-gradient(180deg, transparent, {{ _line_color }}); }
  {%- endif -%}

  #shopify-section-{{ section.id }} .ct-future__heading { font-weight: {{ section.settings.font_weight_heading }}; }
  #shopify-section-{{ section.id }} .ct-future__caption { font-weight: {{ section.settings.font_weight_body }}; }

  {%- if section.settings.heading_font == 'cormorant' -%}
  #shopify-section-{{ section.id }} .ct-future__heading { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; }
  {%- elsif section.settings.heading_font == 'dm-sans' -%}
  #shopify-section-{{ section.id }} .ct-future__heading { font-family: 'DM Sans', 'Helvetica Neue', sans-serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'noto-kr' -%}
  #shopify-section-{{ section.id }} .ct-future__heading { font-family: 'Noto Serif KR', 'Nanum Myeongjo', serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'ny' -%}
  #shopify-section-{{ section.id }} .ct-future__heading { font-family: 'New York', ui-serif, Georgia, serif; font-style: normal; }
  {%- endif -%}
{%- endstyle -%}

<section class="ct-future">

  {%- if _has_image -%}
    {{
      section.settings.image
      | image_url: width: 2000
      | image_tag:
        class: 'ct-future__bg',
        loading: 'lazy',
        alt: section.settings.image.alt
    }}
    <div class="ct-future__overlay"></div>
  {%- endif -%}

  <div class="ct-future__line ct-reveal" aria-hidden="true"></div>
  <h2 class="ct-future__heading ct-reveal ct-reveal--d1">
    {{ section.settings.heading | newline_to_br }}
  </h2>
  {% if section.settings.caption != blank %}
    <p class="ct-future__caption ct-reveal ct-reveal--d2">
      {{ section.settings.caption }}
    </p>
  {% endif %}

</section>

<script src="{{ 'chalttok-sarang.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "CT · Future Close",
  "tag": "div",
  "class": "chalttok-section",
  "settings": [
    {
      "type": "header",
      "content": "배경 이미지"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "배경 이미지",
      "info": "설정하지 않으면 기존 아이보리 배경이 유지됩니다."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "오버레이 불투명도",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 40,
      "info": "높을수록 이미지가 어두워져 텍스트 가독성이 올라갑니다."
    },
    {
      "type": "range",
      "id": "image_focus_y",
      "label": "이미지 세로 초점",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_min_height",
      "label": "섹션 최소 높이",
      "min": 300,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 500,
      "info": "배경 이미지 사용 시 섹션 높이를 조절합니다."
    },
    {
      "type": "header",
      "content": "레이아웃"
    },
    {
      "type": "select",
      "id": "text_v_pos",
      "label": "텍스트 세로 위치",
      "options": [
        { "value": "flex-start", "label": "상단" },
        { "value": "center",     "label": "중앙 (기본)" },
        { "value": "flex-end",   "label": "하단" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "상단 여백",
      "min": 24,
      "max": 240,
      "step": 8,
      "unit": "px",
      "default": 160
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "하단 여백",
      "min": 24,
      "max": 240,
      "step": 8,
      "unit": "px",
      "default": 160
    },
    {
      "type": "header",
      "content": "텍스트"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Sarang is only\nthe beginning."
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption",
      "default": "We grow slowly. Each product we add will ask the same question: does this serve skin, or simply add to it?"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "글자 색상",
      "options": [
        { "value": "default", "label": "기본 (테마 색상)" },
        { "value": "white",   "label": "흰색 / 아이보리 (배경 이미지용)" },
        { "value": "black",   "label": "순수 검정" }
      ],
      "default": "default",
      "info": "배경 이미지 사용 시 '흰색'을 선택하세요."
    },
    {
      "type": "header",
      "content": "폰트"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "헤딩 폰트",
      "options": [
        { "value": "default",   "label": "기본 (현재 폰트 유지)" },
        { "value": "cormorant", "label": "Cormorant (이탤릭 세리프)" },
        { "value": "dm-sans",   "label": "DM Sans (모던 산세리프)" },
        { "value": "noto-kr",   "label": "Noto Serif KR (한글 세리프)" },
        { "value": "ny",        "label": "New York (애플 세리프)" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "폰트 두께"
    },
    {
      "type": "select",
      "id": "font_weight_heading",
      "label": "헤딩 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" },
        { "value": "700", "label": "700 — Bold" }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "font_weight_body",
      "label": "본문 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" }
      ],
      "default": "300"
    }
  ],
  "presets": [
    {
      "name": "CT · Future Close"
    }
  ]
}
{% endschema %}
