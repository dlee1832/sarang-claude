{{ 'chalttok-sarang.css' | asset_url | stylesheet_tag }}

<section class="ct-future">
  <div class="ct-future__line ct-reveal" aria-hidden="true"></div>
  <h2 class="ct-future__heading ct-reveal ct-reveal--d1">
    {{ section.settings.heading | newline_to_br }}
  </h2>
  {% if section.settings.caption != blank %}
    <p class="ct-future__caption ct-reveal ct-reveal--d2">
      {{ section.settings.caption }}
    </p>
  {% endif %}
</section>

<script src="{{ 'chalttok-sarang.js' | asset_url }}" defer></script>



<style>
  #shopify-section-{{ section.id }} .ct-future__heading { font-weight: {{ section.settings.font_weight_heading }}; }
  #shopify-section-{{ section.id }} .ct-future__caption { font-weight: {{ section.settings.font_weight_body }}; }

  {%- if section.settings.heading_font == 'cormorant' -%}
  #shopify-section-{{ section.id }} .ct-future__heading { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; }
  {%- elsif section.settings.heading_font == 'dm-sans' -%}
  #shopify-section-{{ section.id }} .ct-future__heading { font-family: 'DM Sans', 'Helvetica Neue', sans-serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'noto-kr' -%}
  #shopify-section-{{ section.id }} .ct-future__heading { font-family: 'Noto Serif KR', 'Nanum Myeongjo', serif; font-style: normal; }
  {%- elsif section.settings.heading_font == 'ny' -%}
  #shopify-section-{{ section.id }} .ct-future__heading { font-family: 'New York', ui-serif, Georgia, serif; font-style: normal; }
  {%- endif -%}
</style>
{% schema %}
{
  "name": "CT · Future Close",
  "tag": "div",
  "class": "chalttok-section",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Sarang is only\nthe beginning."
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption",
      "default": "We grow slowly. Each product we add will ask the same question: does this serve skin, or simply add to it?"
    },
    {
      "type": "header",
      "content": "폰트"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "헤딩 폰트",
      "options": [
        { "value": "default",   "label": "기본 (현재 폰트 유지)" },
        { "value": "cormorant", "label": "Cormorant (이탤릭 세리프)" },
        { "value": "dm-sans",   "label": "DM Sans (모던 산세리프)" },
        { "value": "noto-kr",   "label": "Noto Serif KR (한글 세리프)" },
        { "value": "ny",        "label": "New York (애플 세리프)" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "폰트 두께"
    },
    {
      "type": "select",
      "id": "font_weight_heading",
      "label": "헤딩 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" },
        { "value": "700", "label": "700 — Bold" }
      ],
      "default": "300"
    },
    {
      "type": "select",
      "id": "font_weight_body",
      "label": "본문 폰트 두께",
      "options": [
        { "value": "200", "label": "200 — Thin" },
        { "value": "300", "label": "300 — Light (기본)" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "600", "label": "600 — SemiBold" }
      ],
      "default": "300"
    }
  ],
  "presets": [
    {
      "name": "CT · Future Close"
    }
  ]
}
{% endschema %}
